@{
    ViewData["Title"] = "Exigences";
    Layout = "~/Views/Partage/_Layout.cshtml";
}

<h1 class="mb-4">Liste des exigences</h1>

<a asp-action="Create" class="btn btn-primary mb-3">
    ➕ Nouvelle exigence
</a>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Libellé</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <!-- Exemple statique -->
        <tr>
            <td>1</td>
            <td>Exigence sécurité</td>
            <td>
                <a asp-action="Details" asp-route-id="1" class="btn btn-info btn-sm">Détails</a>
                <a asp-action="Edit" asp-route-id="1" class="btn btn-warning btn-sm">Modifier</a>
                <a asp-action="Delete" asp-route-id="1" class="btn btn-danger btn-sm">Supprimer</a>
            </td>
        </tr>
    </tbody>
</table>