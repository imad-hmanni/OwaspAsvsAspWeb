@model IEnumerable<Category>
@{ ViewData["Title"] = "Chapitres ASVS"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Chapitres ASVS (@Model.Count())</h2>
    <a asp-action="Create" class="btn btn-primary">+ Nouveau chapitre</a>
</div>

<div class="accordion" id="catAccordion">
    @foreach (var category in Model.OrderBy(c => c.Code))
    {
        string catId = $"cat-{category.Id}";
        <div class="accordion-item border-0 shadow-sm mb-3">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed fw-bold" type="button"
                        data-bs-toggle="collapse" data-bs-target="#@catId">
                    <span class="badge bg-dark me-2">@category.Code</span>
                    @category.Name
                    <span class="badge bg-secondary ms-2 fw-normal">@category.SubCategories.Sum(s => s.Items.Count) exigences</span>
                    <div class="ms-auto d-flex gap-2" onclick="event.stopPropagation()">
                        <a asp-action="Edit" asp-route-id="@category.Id" class="btn btn-sm btn-outline-warning">✏</a>
                        <form asp-action="Delete" asp-route-id="@category.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Supprimer ce chapitre et toutes ses sections/exigences ?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">🗑</button>
                        </form>
                    </div>
                </button>
            </h2>
            <div id="@catId" class="accordion-collapse collapse">
                <div class="accordion-body p-0">
                    @foreach (var sub in category.SubCategories.OrderBy(s => s.Code))
                    {
                        <div class="px-3 py-2 bg-light border-top border-bottom">
                            <strong class="text-primary">@sub.Code</strong> — @sub.Name
                        </div>
                        <table class="table table-sm table-hover mb-0">
                            <tbody>
                                @foreach (var item in sub.Items.OrderBy(i => i.Code))
                                {
                                    string lc = item.Level switch { "1" => "success", "2" => "warning", "3" => "danger", _ => "secondary" };
                                    <tr>
                                        <td class="ps-4 text-nowrap" style="width:90px"><code class="small">@item.Code</code></td>
                                        <td class="small">@item.Description</td>
                                        <td style="width:60px"><span class="badge bg-@lc">L@(item.Level)</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    }
</div>
