@model Category
@{ ViewData["Title"] = "Nouveau chapitre"; }
<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-dark text-white"><h5 class="mb-0">+ Nouveau chapitre ASVS</h5></div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Code (ex: V1)</label>
                        <input asp-for="Code" class="form-control" placeholder="V14" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Nom</label>
                        <input asp-for="Name" class="form-control" placeholder="Architecture, Design et Modélisation des Menaces" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1">Créer</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
