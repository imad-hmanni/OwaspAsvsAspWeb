@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    string riskColor = Model.RiskLevel switch { "Faible" => "success", "Moyen" => "warning", "Élevé" => "danger", _ => "secondary" };
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h2 class="fw-bold mb-0">📊 Dashboard ASVS</h2>
    <a asp-controller="Application" asp-action="Create" class="btn btn-primary btn-sm">+ Nouvelle application</a>
</div>

<!-- KPI Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-1 fw-bold text-primary">@Model.TotalApplications</div>
            <div class="text-muted small">Applications</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-1 fw-bold text-info">@Model.TotalRequirements</div>
            <div class="text-muted small">Exigences ASVS</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-1 fw-bold text-secondary">@Model.TotalAssessments</div>
            <div class="text-muted small">Évaluations</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center p-3 border-@riskColor" style="border-left:4px solid !important">
            <div class="fs-1 fw-bold text-@riskColor">@Model.OverallCompliance%</div>
            <div class="text-muted small">Conformité globale</div>
            <span class="badge bg-@riskColor mt-1">@Model.RiskLevel</span>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Doughnut chart -->
    <div class="col-md-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-bottom fw-semibold">Répartition des statuts</div>
            <div class="card-body d-flex align-items-center justify-content-center" style="min-height:220px">
                <canvas id="statusChart" style="max-height:200px"></canvas>
            </div>
        </div>
    </div>
    <!-- Bar chart by category -->
    <div class="col-md-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-bottom fw-semibold">Conformité par chapitre</div>
            <div class="card-body">
                <canvas id="categoryChart" style="max-height:220px"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Recent applications -->
@if (Model.RecentApplications.Any())
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom fw-semibold d-flex justify-content-between">
            <span>Applications récentes</span>
            <a asp-controller="Application" asp-action="Index" class="btn btn-sm btn-outline-primary">Voir tout</a>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0 small">
                <thead class="table-light">
                    <tr><th>Application</th><th>Conformité</th><th>Risque</th><th>Créée le</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var app in Model.RecentApplications)
                    {
                        string rc = app.RiskLevel switch { "Faible" => "success", "Moyen" => "warning", "Élevé" => "danger", _ => "secondary" };
                        <tr>
                            <td class="fw-semibold">@app.Name</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height:6px;min-width:80px">
                                        <div class="progress-bar bg-@rc" style="width:@((int)app.CompliancePercentage)%"></div>
                                    </div>
                                    <span>@app.CompliancePercentage%</span>
                                </div>
                            </td>
                            <td><span class="badge bg-@rc">@app.RiskLevel</span></td>
                            <td class="text-muted">@app.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                <a asp-controller="Report" asp-action="Index" asp-route-applicationId="@app.Id"
                                   class="btn btn-sm btn-outline-info">Rapport</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
// Status Doughnut
new Chart(document.getElementById('statusChart'), {
    type: 'doughnut',
    data: {
        labels: ['Valide', 'Non valide', 'N/A', 'En attente'],
        datasets: [{
            data: [@Model.ValidCount, @Model.NotValidCount, @Model.NotApplicableCount, @Model.PendingCount],
            backgroundColor: ['#198754','#dc3545','#6c757d','#ffc107'],
            borderWidth: 2
        }]
    },
    options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
});

// Category Bar
const catLabels = [@Html.Raw(string.Join(",", Model.CategoryCompliance.Select(c => $"\"{c.Code}\"")))];
const catData   = [@Html.Raw(string.Join(",", Model.CategoryCompliance.Select(c => c.CompliancePercentage.ToString(System.Globalization.CultureInfo.InvariantCulture))))];
const catColors = catData.map(v => v >= 80 ? '#198754' : v >= 50 ? '#ffc107' : '#dc3545');
new Chart(document.getElementById('categoryChart'), {
    type: 'bar',
    data: {
        labels: catLabels,
        datasets: [{ label: 'Conformité %', data: catData, backgroundColor: catColors, borderRadius: 4 }]
    },
    options: {
        responsive: true,
        scales: { y: { min: 0, max: 100, ticks: { callback: v => v + '%' } } },
        plugins: { legend: { display: false } }
    }
});
</script>
}
