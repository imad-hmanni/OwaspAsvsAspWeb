@model List<UserListItemViewModel>
@{ ViewData["Title"] = "Gestion des utilisateurs"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">👥 Utilisateurs (@Model.Count)</h2>
    <a asp-action="CreateUser" class="btn btn-primary">+ Nouvel utilisateur</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr><th>Nom complet</th><th>Email</th><th>Rôle</th><th>Applications</th><th class="text-end">Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    string rc = u.Role switch { "Admin" => "danger", "Auditor" => "primary", _ => "success" };
                    <tr>
                        <td class="fw-semibold">@(u.FullName ?? "—")</td>
                        <td>@u.Email</td>
                        <td><span class="badge bg-@rc">@u.Role</span></td>
                        <td>@u.ApplicationCount</td>
                        <td class="text-end">
                            <a asp-action="EditUser" asp-route-id="@u.Id" class="btn btn-sm btn-outline-secondary">⚙ Modifier</a>
                            @if (u.Email != "admin@asvs-auditor.com")
                            {
                                <form asp-action="DeleteUser" asp-route-id="@u.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Supprimer cet utilisateur ?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger ms-1">🗑</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
