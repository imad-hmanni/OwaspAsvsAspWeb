@model AdminDashboardViewModel
@{ ViewData["Title"] = "Administration"; }

<h2 class="fw-bold mb-4">⚙ Panneau d'administration</h2>

<div class="row g-3 mb-4">
    <div class="col-6 col-md">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-2 fw-bold text-primary">@Model.TotalUsers</div>
            <div class="text-muted small">Utilisateurs</div>
            <a asp-action="Users" class="btn btn-sm btn-outline-primary mt-2">Gérer</a>
        </div>
    </div>
    <div class="col-6 col-md">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-2 fw-bold text-success">@Model.TotalApplications</div>
            <div class="text-muted small">Applications</div>
            <a asp-controller="Application" asp-action="Index" class="btn btn-sm btn-outline-success mt-2">Voir</a>
        </div>
    </div>
    <div class="col-6 col-md">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-2 fw-bold text-info">@Model.TotalCategories</div>
            <div class="text-muted small">Chapitres ASVS</div>
            <a asp-controller="Category" asp-action="Index" class="btn btn-sm btn-outline-info mt-2">Gérer</a>
        </div>
    </div>
    <div class="col-6 col-md">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-2 fw-bold text-warning">@Model.TotalRequirements</div>
            <div class="text-muted small">Exigences</div>
            <a asp-controller="Item" asp-action="Index" class="btn btn-sm btn-outline-warning mt-2">Gérer</a>
        </div>
    </div>
    <div class="col-6 col-md">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-2 fw-bold text-secondary">@Model.TotalAssessments</div>
            <div class="text-muted small">Évaluations</div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <span>Utilisateurs récents</span>
        <a asp-action="Users" class="btn btn-sm btn-outline-light">Voir tous</a>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0 small">
            <thead class="table-light">
                <tr><th>Nom</th><th>Email</th><th>Rôle</th><th>Applications</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var u in Model.RecentUsers)
                {
                    string rc = u.Role switch { "Admin" => "danger", "Auditor" => "primary", _ => "success" };
                    <tr>
                        <td class="fw-semibold">@(u.FullName ?? "—")</td>
                        <td>@u.Email</td>
                        <td><span class="badge bg-@rc">@u.Role</span></td>
                        <td>@u.ApplicationCount</td>
                        <td>
                            <a asp-action="EditUser" asp-route-id="@u.Id" class="btn btn-sm btn-outline-secondary">⚙</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="row g-3 mt-3">
    <div class="col-md-4">
        <a asp-controller="Category" asp-action="Create" class="btn btn-outline-info w-100">+ Nouveau chapitre</a>
    </div>
    <div class="col-md-4">
        <a asp-controller="SubCategory" asp-action="Create" class="btn btn-outline-primary w-100">+ Nouvelle section</a>
    </div>
    <div class="col-md-4">
        <a asp-controller="Item" asp-action="Create" class="btn btn-outline-warning w-100">+ Nouvelle exigence</a>
    </div>
</div>
