@model EditUserViewModel
@{ ViewData["Title"] = "Modifier l'utilisateur"; }
<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-dark text-white"><h5 class="mb-0">⚙ Modifier l'utilisateur</h5></div>
            <div class="card-body p-4">
                <form asp-action="EditUser" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger py-2 small"></div>
                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-semibold"></label>
                        <input asp-for="FullName" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email" class="form-control" />
                    </div>
                    <div class="mb-4">
                        <label asp-for="Role" class="form-label fw-semibold"></label>
                        <select asp-for="Role" asp-items="ViewBag.Roles" class="form-select"></select>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1">Enregistrer</button>
                        <a asp-action="Users" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
