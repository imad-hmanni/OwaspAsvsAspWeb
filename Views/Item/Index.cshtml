@model List<Item>
@{ ViewData["Title"] = "Exigences ASVS"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Exigences ASVS (@Model.Count)</h2>
    <a asp-action="Create" class="btn btn-primary">+ Nouvelle exigence</a>
</div>
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 small">
                <thead class="table-dark">
                    <tr><th>Code</th><th>Description</th><th>Section</th><th>Niv.</th><th class="text-end">Actions</th></tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><code>@item.Code</code></td>
                            <td style="max-width:400px">@item.Description</td>
                            <td>@item.SubCategory?.Code</td>
                            <td><span class="badge bg-dark">L@(item.Level)</span></td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">⚙</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Supprimer ?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">🗑</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
